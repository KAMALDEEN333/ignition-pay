{
  "name": "stellar-address-kit",
  "version": "1.0.1",
  "description": "TypeScript implementation of the Stellar Address Kit",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{js,json,md}\""
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=10.0.0"
  },
  "devDependencies": {
    "@stellar-address-kit/spec": "workspace:*",
    "@stellar/stellar-sdk": "^12.3.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1",
    "@typescript-eslint/parser": "^6.21.0",
    "prettier": "^3.6.2"
  }
}
