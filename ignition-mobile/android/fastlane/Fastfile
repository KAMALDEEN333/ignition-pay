default_platform(:android)

platform :android do
  desc "Build the release AAB"
  lane :build do
    sh("cd .. && flutter build appbundle --release")
  end

  desc "Upload metadata + screenshots only (no binary) to the internal track"
  lane :metadata do
    upload_to_play_store(
      track: "internal",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_images: false,
      skip_upload_screenshots: false,
    )
  end

  desc "Build and upload a release candidate to the internal testing track"
  lane :internal do
    build
    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
    )
  end

  desc "Promote the current internal release to production"
  lane :promote_to_production do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
